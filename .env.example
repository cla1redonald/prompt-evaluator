# Anthropic API Key — required for running evaluations
# Get yours at: https://console.anthropic.com/
# Add to your shell profile (~/.zshrc, ~/.bashrc, ~/.bash_profile etc)
# or use a secrets manager (Doppler, 1Password CLI)
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}

# OpenAI API Key — required for GPT-4o in Compare Models mode
# Get yours at: https://platform.openai.com/api-keys
# Add to your shell profile (~/.zshrc, ~/.bashrc, ~/.bash_profile etc)
# or use a secrets manager (Doppler, 1Password CLI)
OPENAI_API_KEY=${OPENAI_API_KEY}

# Google AI API Key — required for Gemini in Compare Models mode
# Get yours at: https://aistudio.google.com/
# Add to your shell profile (~/.zshrc, ~/.bashrc, ~/.bash_profile etc)
# or use a secrets manager (Doppler, 1Password CLI)
GOOGLE_AI_API_KEY=${GOOGLE_AI_API_KEY}
